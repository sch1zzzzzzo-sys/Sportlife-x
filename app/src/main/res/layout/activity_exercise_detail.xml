<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#333333"
    android:id="@+id/activityExerciseDetail">

    <!-- Шапка -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center"
        android:background="#3F3F3F">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sport - "
            android:textColor="#FFFFFF"
            android:textSize="35sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="life"
            android:textColor="#00B7B7"
            android:textSize="35sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Контент -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Название упражнения -->
            <TextView
                android:id="@+id/tvExerciseTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Подтягивания"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- Секция: Техника -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#3F3F3F"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Техника:"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <!-- Сердечко (избранное) -->
                    <CheckBox
                        android:id="@+id/chkFavorite"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:button="@null"
                        android:background="@null"

                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTechnique"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="1. Хват: Возьмитесь за перекладину хватом чуть шире плеч, ладони направлены от себя.\n\n2. Вис: Полностью выпрямите руки, расслабьте плечи, но сохраняйте активное напряжение в лопатках.\n\n3. Подъем: На выдохе плавно подтянитесь вверх, сводя лопатки и стремясь коснуться перекладины верхней частью груди. Локти должны двигаться вниз к корпусу.\n\n4. Пик: В верхней точке задержитесь на секунду, подбородок должен оказаться выше перекладины.\n\n5. Спуск: Подконтрольно опуститесь вниз до полного выпрямления рук."
                    android:textColor="#E0E0E0"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <!-- Секция: Видео -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#3F3F3F"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Видео:"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="12dp"/>

                <!-- Placeholder для видео -->
                <FrameLayout
                    android:id="@+id/videoContainer"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="#555555">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_media_play"
                        android:alpha="0.5"/>
                </FrameLayout>
            </LinearLayout>

            <!-- Секция: Инвентарь -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#3F3F3F"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Инвентарь:"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvEquipment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Турник"
                    android:textColor="#E0E0E0"
                    android:textSize="16sp"/>
            </LinearLayout>

            <!-- Секция: Группы мышц -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#3F3F3F"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Группы мышц:"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvMuscle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Дельты"
                    android:textColor="#E0E0E0"
                    android:textSize="16sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Подвал -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        android:background="#3F3F3F">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Назад"
            android:textColor="#FFFFFF"
            app:backgroundTint="#757575"
            app:cornerRadius="24dp" />
    </LinearLayout>

</LinearLayout>