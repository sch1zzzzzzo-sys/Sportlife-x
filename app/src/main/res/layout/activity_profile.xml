<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#333333"
    android:id="@+id/activityProfile">

    <!-- Шапка -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center"
        android:background="#3F3F3F">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sport - "
            android:textColor="#FFFFFF"
            android:textSize="35sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="life"
            android:textColor="#00B7B7"
            android:textSize="35sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Контент -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="#333333">

            <!-- Аватарка -->
            <FrameLayout
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp">

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_background"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/btnChangeAvatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="bottom|end"
                    android:src="@android:drawable/ic_menu_camera"
                    android:background="@drawable/circle_accent"
                    android:padding="8dp"
                    android:contentDescription="Сменить аватар"/>

            </FrameLayout>

            <!-- Единый стиль для всех полей -->
            <!-- Поле: Имя -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Имя"
                android:textColor="#B0B0B0"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:tag="login"

                    android:background="@drawable/profile_field_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:text="Name"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <ImageButton
                    android:id="@+id/imageButton"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center|end"
                    android:layout_marginEnd="10dp"
                    app:srcCompat="@drawable/edit"
                    android:background="@drawable/edit_background"/>

            </FrameLayout>

            <!-- Поле: Экспертность -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Экспертность"
                android:textColor="#B0B0B0"
                android:textSize="14sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                />


            <TextView
                android:id="@+id/tvExpertise"
                android:tag="experts"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:padding="12dp"
                android:background="@drawable/profile_field_bg"
                android:text="None"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp"/>

            <!-- Поле: Активность -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Активность"
                android:textColor="#B0B0B0"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvActivity"
                android:tag="activity"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:padding="12dp"
                android:background="@drawable/profile_field_bg"
                android:text="00"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp"/>

            <!-- Поле: Рейтинг -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Мой рейтинг"
                android:textColor="#B0B0B0"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvRating"
                android:tag="top"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:padding="12dp"
                android:background="@drawable/profile_field_bg"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp"/>


        </LinearLayout>
    </ScrollView>

    <!-- Подвал -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        android:background="#3F3F3F">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="Назад"
            android:textColor="#FFFFFF"
            app:backgroundTint="#757575"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Расписание"
            android:textColor="#FFFFFF"
            app:backgroundTint="#00ACC1"
            app:cornerRadius="24dp" />
    </LinearLayout>

</LinearLayout>